<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <Base>True</Base>
        <AppType>Application</AppType>
        <Config Condition="'$(Config)'==''">Debug</Config>
        <FrameworkType>None</FrameworkType>
        <MainSource>DX.Comply.Tests.dpr</MainSource>
        <Platform Condition="'$(Platform)'==''">Win32</Platform>
        <ProjectGuid>{B1C2D3E4-F5A6-4B7C-8D9E-0F1A2B3C4D5E}</ProjectGuid>
        <ProjectName Condition="'$(ProjectName)'==''">DX.Comply.Tests</ProjectName>
        <ProjectVersion>20.3</ProjectVersion>
        <TargetedPlatforms>3</TargetedPlatforms>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Base)'=='true') or '$(Base_Win32)'!=''">
        <Base_Win32>true</Base_Win32>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Base)'=='true') or '$(Base_Win64)'!=''">
        <Base_Win64>true</Base_Win64>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_1)'!=''">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_2)'!=''">
        <Cfg_2>true</Cfg_2>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <SanitizedProjectName>DX_Comply_Tests</SanitizedProjectName>
        <DCC_DcuOutput>..\build\$(Platform)\$(Config)\dcu</DCC_DcuOutput>
        <DCC_Description>DX.Comply Unit Tests</DCC_Description>
        <DCC_ExeOutput>..\build\$(Platform)\$(Config)</DCC_ExeOutput>
        <DCC_Namespace>System;Xml;Data;Datasnap;Web;Soap;$(DCC_Namespace)</DCC_Namespace>
        <DCC_UnitSearchPath>..\src;..\libs\DUnitX\Source;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
        <VerInfo_Build>0</VerInfo_Build>
        <VerInfo_IncludeVerInfo>true</VerInfo_IncludeVerInfo>
        <VerInfo_Keys>CompanyName=Olaf Monien;FileDescription=DX.Comply Unit Tests;FileVersion=1.0.0.0;InternalName=DX.Comply.Tests;LegalCopyright=Copyright © 2026 Olaf Monien;LegalTrademarks=;OriginalFilename=DX.Comply.Tests.exe;ProductName=DX.Comply;ProductVersion=1.0.0.0;Comments=MIT License</VerInfo_Keys>
        <VerInfo_Locale>1031</VerInfo_Locale>
        <VerInfo_MajorVer>1</VerInfo_MajorVer>
        <VerInfo_MinorVer>0</VerInfo_MinorVer>
        <VerInfo_Release>0</VerInfo_Release>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base_Win32)'!=''">
        <AppEnableHighDPI>true</AppEnableHighDPI>
        <AppEnableRuntimeThemes>true</AppEnableRuntimeThemes>
        <DCC_UsePackage>rtl;xmlrtl;$(DCC_UsePackage)</DCC_UsePackage>
        <Icon_MainIcon>$(BDS)\bin\delphi_PROJECTICON.ico</Icon_MainIcon>
        <Manifest_File>$(BDS)\bin\default_app.manifest</Manifest_File>
        <VerInfo_Keys>CompanyName=Olaf Monien;FileDescription=DX.Comply Unit Tests;FileVersion=1.0.0.0;InternalName=DX.Comply.Tests;LegalCopyright=Copyright © 2026 Olaf Monien;LegalTrademarks=;OriginalFilename=DX.Comply.Tests.exe;ProductName=DX.Comply;ProductVersion=1.0.0.0;Comments=MIT License</VerInfo_Keys>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base_Win64)'!=''">
        <AppEnableHighDPI>true</AppEnableHighDPI>
        <AppEnableRuntimeThemes>true</AppEnableRuntimeThemes>
        <DCC_UsePackage>rtl;xmlrtl;$(DCC_UsePackage)</DCC_UsePackage>
        <Icon_MainIcon>$(BDS)\bin\delphi_PROJECTICON.ico</Icon_MainIcon>
        <Manifest_File>$(BDS)\bin\default_app.manifest</Manifest_File>
        <VerInfo_Keys>CompanyName=Olaf Monien;FileDescription=DX.Comply Unit Tests;FileVersion=1.0.0.0;InternalName=DX.Comply.Tests;LegalCopyright=Copyright © 2026 Olaf Monien;LegalTrademarks=;OriginalFilename=DX.Comply.Tests.exe;ProductName=DX.Comply;ProductVersion=1.0.0.0;Comments=MIT License</VerInfo_Keys>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1)'!=''">
        <DCC_DebugInformation>1</DCC_DebugInformation>
        <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
        <DCC_LocalDebugSymbols>true</DCC_LocalDebugSymbols>
        <DCC_Optimize>false</DCC_Optimize>
        <DCC_SymbolReferenceInfo>1</DCC_SymbolReferenceInfo>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2)'!=''">
        <DCC_DebugInformation>0</DCC_DebugInformation>
        <DCC_Define>RELEASE;$(DCC_Define)</DCC_Define>
        <DCC_LocalDebugSymbols>false</DCC_LocalDebugSymbols>
        <DCC_Optimize>true</DCC_Optimize>
        <DCC_SymbolReferenceInfo>0</DCC_SymbolReferenceInfo>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="DX.Comply.Tests.BuildEvidence.Intf.pas"/>
        <DCCReference Include="DX.Comply.Tests.BuildEvidence.Reader.pas"/>
        <DCCReference Include="DX.Comply.Tests.HashService.pas"/>
        <DCCReference Include="DX.Comply.Tests.FileScanner.pas"/>
        <DCCReference Include="DX.Comply.Tests.ProjectScanner.pas"/>
        <DCCReference Include="DX.Comply.Tests.CycloneDx.Writer.pas"/>
        <DCCReference Include="DX.Comply.Tests.CycloneDx.XmlWriter.pas"/>
        <DCCReference Include="DX.Comply.Tests.Spdx.Writer.pas"/>
        <DCCReference Include="DX.Comply.Tests.Schema.Validator.pas"/>
        <DCCReference Include="DX.Comply.Tests.Engine.pas"/>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Release">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType>Application</Borland.ProjectType>
        <BorlandProject>
            <Delphi.Personality>
                <Source>
                    <Source Name="MainSource">DX.Comply.Tests.dpr</Source>
                </Source>
            </Delphi.Personality>
            <Platforms>
                <Platform value="Android">False</Platform>
                <Platform value="Android64">False</Platform>
                <Platform value="Linux64">False</Platform>
                <Platform value="Win32">True</Platform>
                <Platform value="Win64">True</Platform>
                <Platform value="iOSDevice64">False</Platform>
                <Platform value="iOSSimARM64">False</Platform>
            </Platforms>
            <VersionInfo>
                <VersionInfo Name="IncludeVerInfo">True</VersionInfo>
                <VersionInfo Name="AutoIncBuild">False</VersionInfo>
                <VersionInfo Name="MajorVer">1</VersionInfo>
                <VersionInfo Name="MinorVer">0</VersionInfo>
                <VersionInfo Name="Release">0</VersionInfo>
                <VersionInfo Name="Build">0</VersionInfo>
                <VersionInfo Name="Debug">False</VersionInfo>
                <VersionInfo Name="PreRelease">False</VersionInfo>
                <VersionInfo Name="Special">False</VersionInfo>
                <VersionInfo Name="Private">False</VersionInfo>
                <VersionInfo Name="DLL">False</VersionInfo>
                <VersionInfo Name="Locale">1031</VersionInfo>
                <VersionInfo Name="CodePage">1252</VersionInfo>
            </VersionInfo>
            <VersionInfoKeys>
                <VersionInfoKey Name="CompanyName">Olaf Monien</VersionInfoKey>
                <VersionInfoKey Name="FileDescription">DX.Comply Unit Tests</VersionInfoKey>
                <VersionInfoKey Name="FileVersion">1.0.0.0</VersionInfoKey>
                <VersionInfoKey Name="InternalName">DX.Comply.Tests</VersionInfoKey>
                <VersionInfoKey Name="LegalCopyright">Copyright © 2026 Olaf Monien</VersionInfoKey>
                <VersionInfoKey Name="LegalTrademarks"/>
                <VersionInfoKey Name="OriginalFilename">DX.Comply.Tests.exe</VersionInfoKey>
                <VersionInfoKey Name="ProductName">DX.Comply</VersionInfoKey>
                <VersionInfoKey Name="ProductVersion">1.0.0.0</VersionInfoKey>
                <VersionInfoKey Name="Comments">MIT License</VersionInfoKey>
            </VersionInfoKeys>
        </BorlandProject>
        <ProjectFileVersion>12</ProjectFileVersion>
    </ProjectExtensions>
    <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
    <Import Project="$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj')"/>
    <Import Project="$(MSBuildProjectName).deployproj" Condition="Exists('$(MSBuildProjectName).deployproj')"/>
</Project>
